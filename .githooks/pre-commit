#!/usr/bin/env bash
set -euo pipefail

for blocked_file in "api_keys.json" "navigator_api_keys.json"; do
  if git diff --cached --name-only | grep -Fxq "$blocked_file"; then
    echo "[DrugClaw hook] Refusing to commit $blocked_file"
    echo "Use api_keys.example.json as the committed template."
    exit 1
  fi
done
